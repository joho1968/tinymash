<!DOCTYPE html>
<html lang="en" data-bs-theme="auto">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link href="/ext/bs/css/bootstrap.min.css" rel="stylesheet">
        <link href="/ext/bsi/bootstrap-icons.min.css" rel="stylesheet">
        <link href="/css/tinymash.css" rel="stylesheet">
        <meta http-equiv="cache-control" content="no-cache, no-store, must-revalidate">
        <title>{$title}</title>
    </head>
    <body class="bg-body-secondary">
        <a class="tm-skip-link" href="#tm-main-content">Skip to main content</a>
        <script>
            (() => {
                'use strict';
                const colorMode = window.matchMedia("(prefers-color-scheme: dark)").matches ?
                    "dark" :
                    "light";
                document.querySelector("html").setAttribute("data-bs-theme", colorMode);
            })();
        </script>

        <main class="container-fluid px-1 px-sm-3 px-md-3 py-3" id="tm-main-content" tabindex="-1" style="min-height:550px !important;">
            <div class="row">
                <div class="col-12 w-100">
                    {block content}{/block}
                </div>
            </div>
        </main>

        <!-- Bootstrap -->
        <script src="/ext/bs/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
