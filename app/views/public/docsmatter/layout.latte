<!DOCTYPE html>
{var $theme_screen_cookie_name = (string) ($theme_screen_cookie_name ?? 'tinymashScreen')}
{var $theme_screen_mode = in_array(($theme_screen_mode ?? 'auto'), ['auto', 'light', 'dark'], true) ? (string) $theme_screen_mode : 'auto'}
{var $theme_initial_bs_theme = $theme_screen_mode === 'dark' ? 'dark' : 'light'}
{var $document_title = trim((string) ($document_title ?? $title ?? $site_name ?? 'tinymash'))}
{var $meta_title = trim((string) ($meta_title ?? $document_title))}
{var $meta_description = trim((string) ($meta_description ?? ''))}
{var $meta_url = trim((string) ($meta_url ?? ''))}
{var $meta_type = trim((string) ($meta_type ?? 'website'))}
{var $meta_image = is_array($meta_image ?? null) ? $meta_image : []}
{var $theme_seo = is_array($theme_seo ?? null) ? $theme_seo : []}
{var $theme_seo_entry = is_array($theme_seo_entry ?? null) ? $theme_seo_entry : []}
{var $social_title = trim((string) ($theme_seo['social_title'] ?? $meta_title))}
{var $social_description = trim((string) ($theme_seo['social_description'] ?? $meta_description))}
{var $social_image = is_array($theme_seo['social_image'] ?? null) ? $theme_seo['social_image'] : $meta_image}
{var $site_favicon_png_image = is_array($site_favicon_png_image ?? null) ? $site_favicon_png_image : []}
{var $site_favicon_ico_image = is_array($site_favicon_ico_image ?? null) ? $site_favicon_ico_image : []}
{var $theme_show_public_chrome = ! isset( $theme_show_public_chrome ) || $theme_show_public_chrome}
{var $theme_background_inline_style = trim((string) ($theme_background_inline_style ?? ''))}
{var $theme_background_preload_url = trim((string) ($theme_background_preload_url ?? ''))}
{var $theme_author_space_slug = ''}
{if ! empty( $author_slug )}
    {var $theme_author_space_slug = (string) $author_slug}
{elseif isset( $entry ) && is_array( $entry ) && ( $entry['scope'] ?? '' ) === 'author' && ! empty( $entry['author_slug'] )}
    {var $theme_author_space_slug = (string) $entry['author_slug']}
{/if}
{var $theme_secret_link_author_space_view = ! empty( $theme_secret_link_author_space_view )}
{var $theme_docs_home_url = trim((string) ($theme_docs_home_url ?? ''))}
{var $theme_header_home_url = $theme_docs_home_url !== '' ? $theme_docs_home_url : ($theme_secret_link_author_space_view && $theme_author_space_slug !== '' ? ('/' . $theme_author_space_slug) : $home_url)}
{var $theme_sidebar_pages = ! empty( $theme_page_structure ) ? $theme_page_structure : (is_array($theme_root_page_structure ?? null) ? $theme_root_page_structure : [])}
{var $theme_has_sidebar_pages = ! empty( $theme_sidebar_pages )}
{var $theme_has_sidebar_navigation = ! empty( $theme_sidebar_menu )}
{var $theme_has_header_navigation = ! empty( $theme_navigation_menu )}
{var $theme_has_search = ! empty( $theme_search['enabled'] ) && ! empty( $theme_search['url'] )}
{var $theme_has_sidebar_fragments = ! empty( $theme_public_sidebar_fragments )}
{var $theme_has_footer_fragments = ! empty( $theme_public_footer_fragments )}
{var $theme_has_footer_content = ! empty( $theme_footer_menu ) || $theme_has_footer_fragments}
{var $theme_has_sidebar_content = $theme_has_sidebar_pages || $theme_has_sidebar_navigation || $theme_has_sidebar_fragments || $theme_has_footer_content}
{var $theme_has_mobile_panel = $theme_has_sidebar_content || $theme_has_header_navigation || $theme_has_search}
<html lang="{$site_default_language ?? 'en'}" data-bs-theme="{$theme_initial_bs_theme}"{if $theme_background_inline_style !== ''}{=' style="' . $theme_background_inline_style . '"'|noescape}{/if}>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="color-scheme" content="light dark">
        <script>
            (() => {
                const root = document.documentElement;
                const screenModeCookieName = {=json_encode($theme_screen_cookie_name)|noescape};
                const screenModeStorageKey = screenModeCookieName;
                const cookieMatch = document.cookie.match(new RegExp('(?:^|;\\s*)' + screenModeCookieName.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\$&') + '=([^;]+)'));
                const cookieValue = cookieMatch ? decodeURIComponent(cookieMatch[1]) : '';
                let storedMode = '';
                try {
                    storedMode = window.localStorage ? String(window.localStorage.getItem(screenModeStorageKey) || '') : '';
                } catch (error) {
                    storedMode = '';
                }
                let requestedMode = {=json_encode($theme_screen_mode)|noescape};
                if (storedMode === 'light' || storedMode === 'dark' || storedMode === 'auto') {
                    requestedMode = storedMode;
                } else if (cookieValue === 'light' || cookieValue === 'dark' || cookieValue === 'auto') {
                    requestedMode = cookieValue;
                }
                const resolvedMode = requestedMode === 'auto'
                    ? (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
                    : requestedMode;
                root.setAttribute('data-tm-screen-mode-script', '1');
                root.setAttribute('data-bs-theme', resolvedMode);
                root.style.colorScheme = resolvedMode;
                root.style.backgroundColor = resolvedMode === 'dark' ? '#212529' : '#f8f9fa';
                root.style.color = resolvedMode === 'dark' ? '#dee2e6' : '#212529';
                root.setAttribute('data-tm-screen-mode-ready', '1');
            })();
        </script>
        {if $theme_background_preload_url !== ''}
            <link rel="preload" as="image" href="{$theme_background_preload_url}" fetchpriority="high">
        {/if}
        <script>
            (() => {
                function scrollCurrentNavigationIntoView() {
                    const activeLink = document.querySelector('.tm-docsmatter-page-link.current, .tm-docsmatter-page-link.ancestor');
                    if (!activeLink) {
                        return;
                    }
                    window.setTimeout(() => {
                        const scrollRoot = activeLink.closest('.tm-docsmatter-sidebar, .offcanvas-body');
                        if (!scrollRoot) {
                            activeLink.scrollIntoView({ behavior: 'auto', block: 'center', inline: 'nearest' });
                            return;
                        }

                        const rootRect = scrollRoot.getBoundingClientRect();
                        const linkRect = activeLink.getBoundingClientRect();
                        const relativeTop = linkRect.top - rootRect.top + scrollRoot.scrollTop;
                        scrollRoot.scrollTop = Math.max(0, relativeTop - Math.max(24, ((rootRect.height - linkRect.height) / 2)));
                    }, 10);
                }

                function buildOnPageNavigation() {
                    const contentRoot = document.getElementById('tm-docsmatter-content-body');
                    const tocRoot = document.getElementById('bs5docs-toc') || document.getElementById('tm-docsmatter-toc');
                    if (!contentRoot || !tocRoot) {
                        return;
                    }

                    const headings = Array.from(contentRoot.querySelectorAll('h2'));
                    if (headings.length < 2) {
                        tocRoot.classList.add('d-none');
                        tocRoot.innerHTML = '';
                        return;
                    }

                    let headingCounter = 1;
                    tocRoot.innerHTML = '';

                    const tocHeading = document.createElement('h6');
                    tocHeading.textContent = 'On this page';
                    const tocList = document.createElement('ul');

                    headings.forEach((heading) => {
                        let headingId = heading.getAttribute('id') || '';
                        if (headingId === '') {
                            headingId = 'tm-docsmatter-section-' + headingCounter++;
                            heading.setAttribute('id', headingId);
                        }

                        const sectionTitle = String(heading.textContent || '').trim() || 'Section';
                        const item = document.createElement('li');
                        const link = document.createElement('a');
                        link.className = 'tm-docsmatter-toc-link';
                        link.setAttribute('href', '#' + headingId);
                        link.setAttribute('title', sectionTitle);
                        link.setAttribute('aria-label', sectionTitle);
                        link.textContent = sectionTitle;
                        item.appendChild(link);
                        tocList.appendChild(item);
                    });

                    tocRoot.appendChild(tocHeading);
                    tocRoot.appendChild(tocList);
                    tocRoot.classList.remove('d-none');
                }

                function setupDocsMatterChrome() {
                    scrollCurrentNavigationIntoView();
                    buildOnPageNavigation();
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', setupDocsMatterChrome, { once: true });
                } else {
                    setupDocsMatterChrome();
                }
            })();
        </script>
        <style>
            html {
                background-color: #f8f9fa;
                color: #212529;
            }

            @media (prefers-color-scheme: dark) {
                html {
                    background-color: #212529;
                    color: #dee2e6;
                }
            }

            html[data-bs-theme="dark"] {
                background-color: #212529;
                color: #dee2e6;
            }

            html[data-tm-screen-mode-script="1"]:not([data-tm-screen-mode-ready="1"]) body {
                visibility: hidden;
            }

            body {
                background: transparent !important;
                color: inherit;
                min-height: 100vh;
            }
        </style>
        {foreach ($theme_css_urls ?? []) as $theme_css_url}
            <link href="{$theme_css_url}" rel="stylesheet">
        {/foreach}
        <title>{$document_title}</title>
        {if ! empty( $site_favicon_png_image['url'] )}
            <link rel="icon" type="image/png" href="{$site_favicon_png_image['url']}"{if ! empty( $site_favicon_png_image['width'] ) && ! empty( $site_favicon_png_image['height'] )} sizes="{$site_favicon_png_image['width']}x{$site_favicon_png_image['height']}"{/if}>
            <link rel="apple-touch-icon" href="{$site_favicon_png_image['url']}">
        {/if}
        {if ! empty( $site_favicon_ico_image['url'] )}
            <link rel="icon" type="image/x-icon" href="{$site_favicon_ico_image['url']}">
        {/if}
        <meta name="title" content="{$meta_title}">
        {if ! empty( $theme_seo['canonical_url'] )}
            <link rel="canonical" href="{$theme_seo['canonical_url']}">
        {/if}
        {if $meta_description !== '' || $social_description !== ''}
            {if $meta_description !== ''}
                <meta name="description" content="{$meta_description}">
            {/if}
            <meta property="og:description" content="{$social_description !== '' ? $social_description : $meta_description}">
            <meta name="twitter:description" content="{$social_description !== '' ? $social_description : $meta_description}">
        {/if}
        <meta property="og:type" content="{$meta_type}">
        {if ! empty( $theme_seo['site_name'] )}
            <meta property="og:site_name" content="{$theme_seo['site_name']}">
        {/if}
        <meta property="og:title" content="{$social_title !== '' ? $social_title : $meta_title}">
        <meta name="twitter:title" content="{$social_title !== '' ? $social_title : $meta_title}">
        {if $meta_url !== ''}
            <meta property="og:url" content="{$meta_url}">
        {/if}
        {if ! empty( $theme_seo_entry['published_at_utc'] )}
            <meta property="article:published_time" content="{$theme_seo_entry['published_at_utc']}">
        {/if}
        {if ! empty( $theme_seo_entry['updated_at_utc'] )}
            <meta property="article:modified_time" content="{$theme_seo_entry['updated_at_utc']}">
        {/if}
        {if ! empty( $social_image['url'] )}
            <meta property="og:image" content="{$social_image['url']}">
            <meta name="twitter:image" content="{$social_image['url']}">
            <meta name="twitter:card" content="summary_large_image">
            {if ! empty( $social_image['mime'] )}
                <meta property="og:image:type" content="{$social_image['mime']}">
            {/if}
            {if ! empty( $social_image['width'] )}
                <meta property="og:image:width" content="{$social_image['width']}">
            {/if}
            {if ! empty( $social_image['height'] )}
                <meta property="og:image:height" content="{$social_image['height']}">
            {/if}
            {if ! empty( $social_image['alt_text'] )}
                <meta property="og:image:alt" content="{$social_image['alt_text']}">
            {/if}
        {else}
            <meta name="twitter:card" content="summary">
        {/if}
        {if ! empty( $theme_meta_robots )}
            <meta name="robots" content="{$theme_meta_robots}">
        {/if}
        {if ! empty( $theme_seo['json_ld'] )}
            <script type="application/ld+json">{=json_encode($theme_seo['json_ld'], \JSON_UNESCAPED_SLASHES | \JSON_UNESCAPED_UNICODE)|noescape}</script>
        {/if}
        {foreach ($theme_public_head_tags ?? []) as $theme_public_head_tag}
            {if ($theme_public_head_tag['type'] ?? '') === 'meta'}
                {if ! empty($theme_public_head_tag['name'])}<meta name="{$theme_public_head_tag['name']}" content="{$theme_public_head_tag['content'] ?? ''}">{/if}
                {if ! empty($theme_public_head_tag['property'])}<meta property="{$theme_public_head_tag['property']}" content="{$theme_public_head_tag['content'] ?? ''}">{/if}
            {elseif ($theme_public_head_tag['type'] ?? '') === 'link'}
                <link rel="{$theme_public_head_tag['rel'] ?? ''}" href="{$theme_public_head_tag['href'] ?? ''}">
            {/if}
        {/foreach}
    </head>
    <body class="d-flex flex-column min-vh-100 {$theme_body_classes ?? ''}">
        <a class="tm-skip-link" href="#tm-main-content">Skip to main content</a>
        <script>
            (() => {
                'use strict';
                const screenModeCookieName = {=json_encode($theme_screen_cookie_name)|noescape};
                const screenModeStorageKey = screenModeCookieName;

                function getPreferredTheme() {
                    return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
                }

                function getCookie(nameOfCookie) {
                    const cName = nameOfCookie + '=';
                    const decodedCookies = decodeURIComponent(document.cookie);
                    const cookies = decodedCookies.split('; ');
                    let cookieRes = '';
                    cookies.forEach((val) => {
                        if (val.indexOf(cName) === 0) {
                            cookieRes = val.substring(cName.length);
                        }
                    });
                    return cookieRes;
                }

                function getScreenMode() {
                    try {
                        const storedMode = window.localStorage ? String(window.localStorage.getItem(screenModeStorageKey) || '') : '';
                        if (storedMode === 'light' || storedMode === 'dark' || storedMode === 'auto') {
                            return storedMode;
                        }
                    } catch (error) {
                    }
                    const screenMode = getCookie(screenModeCookieName);
                    if (screenMode === 'light' || screenMode === 'dark' || screenMode === 'auto') {
                        return screenMode;
                    }
                    return 'auto';
                }

                function updateScreenModeMenu(mode) {
                    const screenModeButtons = Array.from(document.querySelectorAll('[data-tm-screen-mode]'));
                    screenModeButtons.forEach((button) => {
                        const buttonMode = button.getAttribute('data-tm-screen-mode') || '';
                        button.classList.toggle('active', buttonMode === mode);
                        button.setAttribute('aria-pressed', buttonMode === mode ? 'true' : 'false');
                    });
                }

                function applyScreenMode(mode) {
                    const effectiveMode = mode === 'auto' ? getPreferredTheme() : mode;
                    document.documentElement.setAttribute('data-bs-theme', effectiveMode);
                    document.documentElement.style.colorScheme = effectiveMode;
                    document.documentElement.style.backgroundColor = effectiveMode === 'dark' ? '#212529' : '#f8f9fa';
                    document.documentElement.style.color = effectiveMode === 'dark' ? '#dee2e6' : '#212529';
                    updateScreenModeMenu(mode);
                }

                function setScreenMode(mode) {
                    const secureSuffix = window.location.protocol === 'https:' ? '; Secure' : '';
                    try {
                        if (window.localStorage) {
                            window.localStorage.setItem(screenModeStorageKey, mode);
                        }
                    } catch (error) {
                    }
                    document.cookie = screenModeCookieName + '=' + mode + '; Path=/; SameSite=Strict; Max-Age=7776000' + secureSuffix + ';';
                    applyScreenMode(mode);
                }

                const initialScreenMode = getScreenMode();
                applyScreenMode(initialScreenMode);

                function bindScreenModeButtons() {
                    const screenModeButtons = Array.from(document.querySelectorAll('[data-tm-screen-mode]'));
                    screenModeButtons.forEach((button) => {
                        button.addEventListener('click', () => {
                            const requestedMode = button.getAttribute('data-tm-screen-mode') || 'auto';
                            setScreenMode(requestedMode);
                        });
                    });
                    updateScreenModeMenu(getScreenMode());
                }

                function bindSearchForms() {
                    const searchForms = Array.from(document.querySelectorAll('[data-tm-search-form]'));
                    searchForms.forEach((form) => {
                        form.addEventListener('submit', (event) => {
                            const input = form.querySelector('[data-tm-search-input]');
                            if (!(input instanceof HTMLInputElement)) {
                                return;
                            }
                            const trimmedValue = input.value.trim();
                            input.value = trimmedValue;
                            if (trimmedValue === '') {
                                event.preventDefault();
                                input.focus();
                            }
                        });
                    });
                }

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', () => {
                        bindScreenModeButtons();
                        bindSearchForms();
                    }, { once: true });
                } else {
                    bindScreenModeButtons();
                    bindSearchForms();
                }

                const colorSchemeQuery = window.matchMedia('(prefers-color-scheme: dark)');
                const updateAutoTheme = () => {
                    if (getScreenMode() === 'auto') {
                        applyScreenMode('auto');
                    }
                };
                if (colorSchemeQuery && typeof colorSchemeQuery.addEventListener === 'function') {
                    colorSchemeQuery.addEventListener('change', updateAutoTheme);
                } else if (colorSchemeQuery && typeof colorSchemeQuery.addListener === 'function') {
                    colorSchemeQuery.addListener(updateAutoTheme);
                }
            })();
        </script>

        <header n:if="$theme_show_public_chrome" class="container-fluid px-0 bg-body fixed-top z-3 tm-docsmatter-header">
            <div class="container-fluid tm-docsmatter-header-inner">
                <div class="d-flex align-items-center gap-2 h-100">
                    <button n:if="$theme_has_mobile_panel" class="btn btn-outline-secondary btn-sm d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#tm-docsmatter-sidebar" aria-controls="tm-docsmatter-sidebar" aria-label="Browse site navigation" title="Browse">
                        <span class="bi bi-list" aria-hidden="true"></span>
                        <span class="visually-hidden">Browse</span>
                    </button>
                    <div class="d-inline-flex flex-wrap align-items-center gap-2 me-auto">
                        <a class="text-decoration-none text-body-emphasis d-inline-flex align-items-center gap-2" href="{$theme_header_home_url}">
                            <span class="fw-semibold fs-5">{$site_name}</span>
                        </a>
                        {if $theme_author_space_slug !== ''}
                            <a class="text-decoration-none d-inline-flex align-items-center" href="/{$theme_author_space_slug}">
                                <span class="small font-monospace text-body-secondary">~ /home/{$theme_author_space_slug}</span>
                            </a>
                            <a n:if="! empty( $author_home_can_edit ) && ! empty( $author_home_edit_url )" class="btn btn-outline-primary btn-sm" href="{$author_home_edit_url}">Edit</a>
                        {/if}
                    </div>
                    <div class="d-flex flex-wrap align-items-center gap-2 ms-auto">
                        {if $theme_has_search}
                            <form class="d-none d-md-flex align-items-center flex-nowrap" method="get" action="{$theme_search['url']}" data-tm-search-form>
                                <label class="visually-hidden" for="tm-docsmatter-header-search">Search</label>
                                <div class="input-group input-group-sm flex-nowrap" style="max-width: 16rem;">
                                    <input class="form-control font-monospace" id="tm-docsmatter-header-search" type="search" name="q" value="{$theme_search['query'] ?? ''}" minlength="{$theme_search['min_query_length'] ?? 2}" placeholder="Search docs" data-tm-search-input>
                                    <button class="btn btn-outline-secondary" type="submit" title="Search" aria-label="Search">
                                        <span class="bi bi-search" aria-hidden="true"></span>
                                        <span class="visually-hidden">Search</span>
                                    </button>
                                </div>
                                {if ! empty( $theme_search['author_slug'] )}
                                    <input type="hidden" name="author" value="{$theme_search['author_slug']}">
                                {/if}
                            </form>
                        {/if}
                        {if $theme_has_header_navigation}
                            <nav class="d-none d-lg-flex align-items-center gap-2 tm-docsmatter-header-menu" aria-label="Primary">
                                {foreach $theme_navigation_menu as $page}
                                    {if ! empty( $page['is_separator'] )}
                                        <div class="vr align-self-center opacity-50" aria-hidden="true"></div>
                                    {elseif ! empty( $page['children'] )}
                                        <div n:class="'dropdown tm-docsmatter-header-parent', ($page['url'] ?? '') !== '#' && trim((string) ($page['url'] ?? '')) !== '' ? 'btn-group'">
                                            {if ($page['url'] ?? '') !== '#' && trim((string) ($page['url'] ?? '')) !== ''}
                                                <a n:class="'btn btn-outline-secondary btn-sm', ! empty($page['is_current']) || ! empty($page['is_ancestor']) ? 'active'" href="{$page['url']}" n:attr="target => !empty($page['target']) ? $page['target'] : null, rel => !empty($page['rel']) ? $page['rel'] : null">{$page['title']}</a>
                                                <button n:class="'btn btn-outline-secondary btn-sm dropdown-toggle dropdown-toggle-split', ! empty($page['is_current']) || ! empty($page['is_ancestor']) ? 'active'" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Show submenu for {$page['title']}">
                                                    <span class="visually-hidden">Show submenu for {$page['title']}</span>
                                                </button>
                                            {else}
                                                <button n:class="'btn btn-outline-secondary btn-sm dropdown-toggle', ! empty($page['is_current']) || ! empty($page['is_ancestor']) ? 'active'" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                    {$page['title']}
                                                </button>
                                            {/if}
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                {include './partials/navigation-menu-items.latte', items: $page['children'], level: 2}
                                            </ul>
                                        </div>
                                    {else}
                                        <a n:class="'btn btn-outline-secondary btn-sm', ! empty($page['is_current']) ? 'active'" href="{$page['url']}" n:attr="target => !empty($page['target']) ? $page['target'] : null, rel => !empty($page['rel']) ? $page['rel'] : null">{$page['title']}</a>
                                    {/if}
                                {/foreach}
                            </nav>
                        {/if}
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Open screen mode menu" title="Screen mode">
                                <span class="bi bi-circle-half" aria-hidden="true"></span>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><h6 class="dropdown-header">Screen mode</h6></li>
                                <li><button class="dropdown-item" type="button" data-tm-screen-mode="auto">Auto</button></li>
                                <li><button class="dropdown-item" type="button" data-tm-screen-mode="light">Light</button></li>
                                <li><button class="dropdown-item" type="button" data-tm-screen-mode="dark">Dark</button></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <div n:if="$theme_has_mobile_panel" class="offcanvas offcanvas-start" tabindex="-1" id="tm-docsmatter-sidebar" role="dialog" aria-labelledby="tm-docsmatter-sidebar-title">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="tm-docsmatter-sidebar-title">Browse</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body bg-body-tertiary">
                {if $theme_has_search}
                    <form class="mb-3 d-md-none" method="get" action="{$theme_search['url']}" data-tm-search-form>
                        <label class="visually-hidden" for="tm-docsmatter-offcanvas-search">Search</label>
                        <div class="input-group input-group-sm flex-nowrap">
                            <input class="form-control font-monospace" id="tm-docsmatter-offcanvas-search" type="search" name="q" value="{$theme_search['query'] ?? ''}" minlength="{$theme_search['min_query_length'] ?? 2}" placeholder="Search docs" data-tm-search-input>
                            <button class="btn btn-outline-secondary" type="submit" title="Search" aria-label="Search">
                                <span class="bi bi-search" aria-hidden="true"></span>
                                <span class="visually-hidden">Search</span>
                            </button>
                        </div>
                        {if ! empty( $theme_search['author_slug'] )}
                            <input type="hidden" name="author" value="{$theme_search['author_slug']}">
                        {/if}
                    </form>
                {/if}
                {include './partials/sidebar-content.latte',
                    sidebar_pages: $theme_sidebar_pages,
                    sidebar_navigation_menu: ! empty($theme_sidebar_menu) ? $theme_sidebar_menu : $theme_navigation_menu,
                    sidebar_footer_menu: $theme_footer_menu,
                    sidebar_fragments: $theme_public_sidebar_fragments,
                    sidebar_footer_fragments: $theme_public_footer_fragments,
                    sidebar_site_name: $site_name,
                    sidebar_site_slogan: $site_slogan,
                    sidebar_theme_name: $theme_name,
                    sidebar_navigation_collapsible: true,
                    sidebar_navigation_prefix: 'tm-docsmatter-mobile-menu'}
            </div>
        </div>

        <div class="container-fluid px-0 flex-grow-1 tm-docsmatter-shell">
            <div class="row g-0 h-100">
                <aside n:if="$theme_has_sidebar_content" class="col-lg-4 col-xl-3 d-none d-lg-block tm-docsmatter-sidebar-column bg-body-tertiary">
                    <div class="tm-docsmatter-sidebar menu-area">
                        {include './partials/sidebar-content.latte',
                            sidebar_pages: $theme_sidebar_pages,
                            sidebar_navigation_menu: $theme_sidebar_menu,
                            sidebar_footer_menu: $theme_footer_menu,
                            sidebar_fragments: $theme_public_sidebar_fragments,
                            sidebar_footer_fragments: $theme_public_footer_fragments,
                            sidebar_site_name: $site_name,
                            sidebar_site_slogan: $site_slogan,
                            sidebar_theme_name: $theme_name,
                            sidebar_navigation_collapsible: false}
                    </div>
                </aside>
                <main id="tm-main-content" tabindex="-1" n:class="$theme_has_sidebar_content ? 'col-12 col-lg-8 col-xl-9 tm-docsmatter-main-column content-area bg-body' : 'col-12 tm-docsmatter-main-column content-area bg-body'">
                    <div id="content-area-inner" n:class="$theme_content_width_class ?? 'tm-content-width-default', 'container-fluid', 'tm-docsmatter-main-inner', 'page-content'">
                        {block content}{/block}
                    </div>
                </main>
            </div>
        </div>

        {foreach ($theme_js_urls ?? []) as $theme_js_url}
            <script src="{$theme_js_url}"></script>
        {/foreach}
    </body>
</html>
