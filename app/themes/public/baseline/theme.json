{
    "key": "baseline",
    "name": "Baseline",
    "description": "Default public theme",
    "version": "1.0.0",
    "template_root": "public/baseline",
    "views": {
        "home": "public/baseline/home.latte",
        "author-home": "public/baseline/author.home.latte",
        "entry-post": "public/baseline/entry.latte",
        "entry-page": "public/baseline/entry.latte",
        "404": "public/baseline/404.latte"
    },
    "css_urls": [
        "/ext/bs/css/bootstrap.min.css",
        "/ext/bsi/bootstrap-icons.min.css",
        "/css/tinymash.css"
    ],
    "js_urls": [
        "/ext/bs/js/bootstrap.bundle.min.js"
    ],
    "supports": {
        "menus": true,
        "primary_menu": true,
        "sidebar_menu": true,
        "breadcrumbs": true,
        "page_sidebar": true,
        "after_content_child_pages": true,
        "footer_menu": true,
        "public_background": true,
        "syntax_highlighting": true
    },
    "settings_schema": [
        {
            "key": "primary_menu_position",
            "label": "Primary menu position",
            "type": "select",
            "default": "header",
            "options": [
                {
                    "value": "header",
                    "label": "Header"
                },
                {
                    "value": "sidebar",
                    "label": "Sidebar"
                },
                {
                    "value": "off",
                    "label": "Off"
                }
            ],
            "help": "Controls where the primary site menu is rendered when a menu is configured."
        },
        {
            "key": "footer_menu_position",
            "label": "Footer menu position",
            "type": "select",
            "default": "footer",
            "options": [
                {
                    "value": "footer",
                    "label": "Footer"
                },
                {
                    "value": "off",
                    "label": "Off"
                }
            ],
            "help": "Controls whether the configured footer menu is rendered by this theme."
        },
        {
            "key": "root_landing_mode",
            "label": "Root start page",
            "type": "select",
            "default": "blogroll",
            "options": [
                {
                    "value": "blogroll",
                    "label": "Blogroll"
                },
                {
                    "value": "page",
                    "label": "Static page"
                }
            ],
            "help": "Controls whether the public root space starts on the aggregated post list or a published static page."
        },
        {
            "key": "landing_page_path",
            "label": "Root landing page path",
            "type": "text",
            "lookup": "published_pages",
            "default": "",
            "help": "Used when `Static page` is selected. Choose one of the published root pages."
        },
        {
            "key": "content_width",
            "label": "Content width",
            "type": "select",
            "author_override": true,
            "default": "theme_default",
            "options": [
                {
                    "value": "theme_default",
                    "label": "Theme default"
                },
                {
                    "value": "small",
                    "label": "Small (600)"
                },
                {
                    "value": "compact",
                    "label": "Compact (720)"
                },
                {
                    "value": "reading",
                    "label": "Reading (840)"
                },
                {
                    "value": "standard",
                    "label": "Standard (960)"
                },
                {
                    "value": "wide",
                    "label": "Wide (1140)"
                },
                {
                    "value": "full",
                    "label": "Full"
                }
            ],
            "help": "Bounds the main public content area using tinymash width presets instead of free-form pixel values."
        },
        {
            "key": "publication_title_style",
            "label": "Publication title style",
            "type": "select",
            "default": "sans-serif",
            "options": [
                {
                    "value": "serif",
                    "label": "Serif"
                },
                {
                    "value": "sans-serif",
                    "label": "Sans-serif"
                }
            ],
            "help": "Controls the type style for site identity and publication titles. Body text, navigation and controls remain sans-serif."
        },
        {
            "key": "show_search",
            "label": "Public search",
            "type": "select",
            "default": "enabled",
            "options": [
                {
                    "value": "enabled",
                    "label": "Enabled"
                },
                {
                    "value": "disabled",
                    "label": "Disabled"
                }
            ],
            "help": "Controls whether the public search form is shown when the Search plugin is active."
        },
        {
            "key": "show_tags",
            "label": "Show tags",
            "type": "select",
            "default": "enabled",
            "options": [
                {
                    "value": "enabled",
                    "label": "Enabled"
                },
                {
                    "value": "disabled",
                    "label": "Disabled"
                }
            ],
            "help": "Controls whether entry tags are shown publicly in this theme when tags are enabled sitewide."
        },
        {
            "key": "enable_syntax_highlighting",
            "label": "Enable syntax highlighting",
            "type": "select",
            "requires_plugin": "syntax-highlighting",
            "default": "enabled",
            "options": [
                {
                    "value": "enabled",
                    "label": "Enabled"
                },
                {
                    "value": "disabled",
                    "label": "Disabled"
                }
            ],
            "help": "Uses local highlight.js assets for fenced code blocks in this theme."
        },
        {
            "key": "page_sidebar_style",
            "label": "Page sidebar style",
            "type": "select",
            "default": "flat",
            "options": [
                {
                    "value": "flat",
                    "label": "Flat list"
                },
                {
                    "value": "cards",
                    "label": "Card tree"
                },
                {
                    "value": "disabled",
                    "label": "Disabled"
                }
            ],
            "help": "Controls how published page trees render in the sidebar."
        },
        {
            "key": "top_navigation_depth",
            "label": "Top navigation depth",
            "type": "select",
            "default": "1",
            "options": [
                {
                    "value": "disabled",
                    "label": "Disabled"
                },
                {
                    "value": "1",
                    "label": "1st level"
                },
                {
                    "value": "2",
                    "label": "2nd level"
                },
                {
                    "value": "3",
                    "label": "3rd level"
                }
            ],
            "help": "Used for the fallback page-tree menu when no primary menu is configured and the position is set to `Header`."
        },
        {
            "key": "page_breadcrumbs",
            "label": "Page breadcrumbs",
            "type": "select",
            "default": "enabled",
            "options": [
                {
                    "value": "enabled",
                    "label": "Enabled"
                },
                {
                    "value": "disabled",
                    "label": "Disabled"
                }
            ],
            "help": "Controls whether page breadcrumb trails are shown above page content."
        },
        {
            "key": "page_children_after_content",
            "label": "After-content child pages",
            "type": "select",
            "default": "more",
            "options": [
                {
                    "value": "disabled",
                    "label": "Disabled"
                },
                {
                    "value": "more",
                    "label": "More"
                },
                {
                    "value": "subpages",
                    "label": "Sub pages"
                }
            ],
            "help": "Controls whether published child pages are listed after page content."
        },
        {
            "key": "post_summary_fallback",
            "label": "Short summary format for posts",
            "type": "select",
            "default": "words",
            "options": [
                {
                    "value": "words",
                    "label": "Short summary"
                },
                {
                    "value": "full",
                    "label": "Full post"
                },
                {
                    "value": "title",
                    "label": "Only title"
                }
            ],
            "help": "Controls what the root and author post lists show when a post has no explicit summary."
        },
        {
            "key": "post_summary_fallback_words",
            "label": "Short summary words",
            "type": "text",
            "default": "40",
            "help": "Used when `Short summary` is selected. Invalid values fall back to 40."
        }
    ]
}
