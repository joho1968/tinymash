{extends 'generic.layout.latte'}

{block content}
    <div class="mt-5 mx-2 text-center">
        <div class="h2 font-monospace d-inline-block">
            <span class="text-bg-danger px-1 pt-1 rounded-2">Oh snap!</span> {$title}
        </div>
        <div class="mt-3 font-monospace">
            It seems like some sort of error has occurred, this is probably on us.
            <div class="d-block d-md-inline-block">
                Sorry about that.
            </div>
        </div>
    </div>
{/block}
