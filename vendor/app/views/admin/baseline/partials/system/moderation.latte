<section class="p-3 bg-body border rounded-3 shadow-sm">
    <div class="small text-uppercase text-body-secondary mb-2">Moderation</div>
    <div class="fw-semibold mb-1">Content moderation policy</div>
    <div class="row g-3">
        <div class="col-12 col-xxl-6">
            <form method="post" action="{$system_settings_url}">
                <input type="hidden" name="tinymash_csrf" value="{$csrf_token}">
                <input type="hidden" name="settings_group" value="moderation">
                <div class="rounded-3 p-3 bg-body-secondary h-100">
                    <div class="form-check">
                        <input class="form-check-input" id="tm-system-require-moderation" name="require_moderation" type="checkbox" n:attr="checked => $system_settings['require_moderation']">
                        <label class="form-check-label" for="tm-system-require-moderation">Require content moderation</label>
                        <div class="form-text">When enabled, author-level accounts' publish actions are stored for review instead of going live immediately.</div>
                    </div>
                    <div class="mt-3">
                        <button class="btn btn-primary btn-sm" type="submit">Save moderation policy</button>
                    </div>
                </div>
            </form>
        </div>
        <div class="col-12 col-xxl-6">
            <div class="rounded-3 p-3 bg-body-secondary h-100">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                    <div class="fw-semibold me-auto">Pending review queue</div>
                    <span class="badge {if ($content_stats['pending_review'] ?? 0) > 0}text-bg-warning{else}text-bg-success{/if}">{$content_stats['pending_review'] ?? 0} pending</span>
                </div>
                {if empty( $system_moderation_entries )}
                    <div class="small text-body-secondary">No content is waiting for review right now.</div>
                {else}
                    <div class="d-grid gap-3">
                        {foreach $system_moderation_entries as $entry}
                            <div class="border rounded-3 p-3 bg-body">
                                <div class="d-flex flex-wrap align-items-start justify-content-between gap-2 mb-2">
                                    <div>
                                        <div class="fw-semibold">{$entry['title']}</div>
                                        <div class="small text-body-secondary font-monospace">{$entry['scope'] === 'author' ? $entry['author_slug'] : 'root'} | {$entry['path']}</div>
                                    </div>
                                    <div class="d-flex flex-wrap gap-2">
                                        <span class="badge text-bg-warning">Pending review</span>
                                        <span class="badge border bg-body-tertiary text-body-secondary">{$entry['type']}</span>
                                        <span class="badge text-bg-secondary">{$entry['revision_count']} revisions</span>
                                    </div>
                                </div>
                                <div class="small text-body-secondary mb-3">Updated {$entry['updated_at_display']}</div>
                                <div class="d-flex flex-wrap gap-2">
                                    <a class="btn btn-outline-secondary btn-sm" href="{$entry['open_url']}">Open in composer</a>
                                    <form method="post" action="{$system_moderation_approve_url}">
                                        <input type="hidden" name="tinymash_csrf" value="{$csrf_token}">
                                        <input type="hidden" name="entry_id" value="{$entry['id']}">
                                        <button class="btn btn-success btn-sm" type="submit">Approve</button>
                                    </form>
                                    <form method="post" action="{$system_moderation_reject_url}">
                                        <input type="hidden" name="tinymash_csrf" value="{$csrf_token}">
                                        <input type="hidden" name="entry_id" value="{$entry['id']}">
                                        <button class="btn btn-outline-danger btn-sm" type="submit">Reject</button>
                                    </form>
                                </div>
                            </div>
                        {/foreach}
                    </div>
                {/if}
            </div>
        </div>
    </div>
</section>
