                    const sortableDirection = (event, target, dragElement) => {
                        if (!(target instanceof HTMLElement) || !(dragElement instanceof HTMLElement)) {
                            return 'vertical';
                        }
                        const targetRect = target.getBoundingClientRect();
                        const dragRect = dragElement.getBoundingClientRect();
                        const targetCenterY = targetRect.top + targetRect.height / 2;
                        const dragCenterY = dragRect.top + dragRect.height / 2;
                        const sameRowTolerance = Math.min(targetRect.height, dragRect.height) * 0.6;
                        return Math.abs(targetCenterY - dragCenterY) <= sameRowTolerance ? 'horizontal' : 'vertical';
                    };
                    const sortableMove = (event) => {
                        const target = event && event.related instanceof HTMLElement ? event.related : null;
                        const dragElement = event && event.dragged instanceof HTMLElement ? event.dragged : null;
                        if (!(target instanceof HTMLElement) || !(dragElement instanceof HTMLElement)) {
                            return true;
                        }
                        if (sortableDirection(event.originalEvent || event, target, dragElement) !== 'horizontal') {
                            return true;
                        }
                        const currentItems = items();
                        const from = currentItems.indexOf(dragElement);
                        const to = currentItems.indexOf(target);
                        if (from === -1 || to === -1 || from === to) {
                            return true;
                        }
                        return from > to ? -1 : 1;
                    };
                    const sameRowPointerAssist = (event) => {
                        if (!(activeDrag instanceof HTMLElement)) {
                            return;
                        }
                        const point = pointFromEvent(event);
                        if (!point) {
                            return;
                        }
