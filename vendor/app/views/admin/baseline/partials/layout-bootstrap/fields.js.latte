                        const target = stack
                            .map((element) => itemForTarget(element))
                            .find((item) => item instanceof HTMLElement && item !== activeDrag && item.closest('[data-tm-reorder-list]') === list);
                        if (!(target instanceof HTMLElement) || sortableDirection(event, target, activeDrag) !== 'horizontal') {
