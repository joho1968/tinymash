                function setupFilterableSelect(filterField) {
                    if (!(filterField instanceof HTMLInputElement) || filterField.getAttribute('data-tm-filter-select-initialized') === '1') {
                        return;
                    }
                    filterField.setAttribute('data-tm-filter-select-initialized', '1');
                    const targetSelector = filterField.getAttribute('data-tm-filter-select') || '';
                    if (targetSelector === '') {
                        return;
                    }
                    const selectField = document.querySelector(targetSelector);
                    if (!(selectField instanceof HTMLSelectElement)) {
                        return;
                    }

                    const optionData = Array.from(selectField.options).map((option) => ({
                        value: option.value,
                        label: option.textContent || option.value || '',
                        selected: option.selected,
                    }));

                    function renderOptions() {
                        const query = (filterField.value || '').trim().toLowerCase();
                        const currentValue = selectField.value;
                        const visibleOptions = optionData.filter((option) => {
                            if (option.value === '') {
                                return true;
                            }
                            return query === '' || option.label.toLowerCase().includes(query) || option.value.toLowerCase().includes(query);
                        });

                        selectField.innerHTML = '';
                        visibleOptions.forEach((option) => {
                            const optionElement = document.createElement('option');
                            optionElement.value = option.value;
                            optionElement.textContent = option.label;
                            optionElement.selected = option.value === currentValue || (currentValue === '' && option.selected);
                            selectField.appendChild(optionElement);
                        });

                        if (selectField.options.length > 0 && selectField.selectedIndex === -1) {
                            selectField.selectedIndex = 0;
                        }
                    }

                    selectField.addEventListener('change', () => {
                        optionData.forEach((option) => {
                            option.selected = option.value === selectField.value;
                        });
                    });

                    filterField.addEventListener('input', renderOptions);
                    renderOptions();
                }
                function setupValidatedDatalist(inputField) {
                    if (!(inputField instanceof HTMLInputElement) || inputField.getAttribute('data-tm-validated-list-initialized') === '1') {
                        return;
                    }
                    inputField.setAttribute('data-tm-validated-list-initialized', '1');
                    const listId = inputField.getAttribute('data-tm-validate-list') || inputField.getAttribute('list') || '';
                    if (listId === '') {
                        return;
                    }
                    const dataList = document.getElementById(listId);
                    if (!(dataList instanceof HTMLDataListElement)) {
                        return;
                    }
                    const allowEmpty = inputField.getAttribute('data-tm-allow-empty') === '1';
                    const invalidMessage = inputField.getAttribute('data-tm-invalid-message') || 'Choose a valid value from the list.';
                    const allowedValues = Array.from(dataList.options).map((option) => (option.value || '').trim()).filter((value) => value !== '');

                    const syncValidity = () => {
                        const currentValue = (inputField.value || '').trim();
                        const isValid = currentValue === ''
                            ? allowEmpty
                            : allowedValues.includes(currentValue);
                        inputField.setCustomValidity(isValid ? '' : invalidMessage);
                        inputField.classList.toggle('is-invalid', !isValid);
                        return isValid;
