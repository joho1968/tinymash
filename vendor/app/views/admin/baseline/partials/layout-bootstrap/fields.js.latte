                    const items = () => Array.from(list.querySelectorAll(itemSelector))
                        .filter((item) => item instanceof HTMLElement && item.closest('[data-tm-reorder-list]') === list);
                    const itemForTarget = (target) => target instanceof Element ? target.closest(itemSelector) : null;
                    const pointFromEvent = (event) => {
                        const point = event && event.touches && event.touches.length > 0 ? event.touches[0] : event;
                        if (!point || typeof point.clientX !== 'number' || typeof point.clientY !== 'number') {
