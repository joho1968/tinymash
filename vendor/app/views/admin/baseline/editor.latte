{extends 'layout.latte'}

{block content}
    {var $editor_plugin_tabs = is_array($editor_plugin_tabs ?? null) ? $editor_plugin_tabs : []}
    {var $editor_json_flags = \JSON_HEX_TAG | \JSON_HEX_APOS | \JSON_HEX_AMP | \JSON_HEX_QUOT}
    <div id="tm-editor-root" data-editor-url="{$editor_url}" data-preview-url="{$preview_url}" data-draft-url="{$draft_url}" data-draft-delete-url="{$draft_delete_url}" data-save-entry-url="{$publish_url}" data-cancel-url="{$editor_cancel_url}" data-slug-check-url="{$editor_slug_check_url}" data-content-search-url="{$editor_content_search_url}" data-media-picker-url="{$editor_media_picker_url}" data-image-upload-url="{$editor_image_upload['upload_url'] ?? ''}" data-images-enabled="{if ! empty( $editor_image_upload['enabled'] )}1{else}0{/if}" data-csrf-token="{$csrf_token}" data-current-author-slug="{$current_author_slug ?? ''}" data-loaded-entry-id="{$editor_loaded_entry_id}" data-loaded-entry-type="{$editor_draft['entry_type'] ?? ''}" data-loaded-entry-scope="{$editor_draft['scope'] ?? ''}" data-loaded-entry-author-slug="{$editor_draft['author_slug'] ?? ''}" data-loaded-draft-id="{$editor_loaded_draft_id}" data-loaded-revision-id="{$editor_loaded_revision_id}" data-attachment-session-id="{$editor_attachment_session_id ?? ''}" data-autosave-enabled="{if ! empty( $editor_autosave['enabled'] )}1{else}0{/if}" data-autosave-interval-seconds="{$editor_autosave['interval_seconds'] ?? 120}" data-emoji-data-url="/ext/emoji-picker-data/en/github/data" data-revisions-json='{json_encode($editor_revisions ?? [], $editor_json_flags)}' data-linkable-entries-json='{json_encode($editor_linkable_entries ?? [], $editor_json_flags)}' data-tag-suggestions-json='{json_encode($editor_tag_suggestions ?? [], $editor_json_flags)}' data-current-featured-image-json='{json_encode($editor_current_featured_image ?? [], $editor_json_flags)}' data-current-social-image-json='{json_encode($editor_current_social_image ?? [], $editor_json_flags)}'>
        {if ! empty( $editor_notice )}
            <div class="alert alert-{$editor_notice['type']} mb-3" role="alert">
                <div>{$editor_notice['message']}</div>
                {if ! empty( $editor_notice['actions'] )}
                    <div class="d-flex flex-wrap gap-2 mt-3">
                        {foreach $editor_notice['actions'] as $notice_action}
                            <a class="{$notice_action['class'] ?? 'btn btn-sm btn-outline-secondary'}" href="{$notice_action['url']}">{$notice_action['label']}</a>
                        {/foreach}
                    </div>
                {/if}
            </div>
        {/if}
        <div class="row g-3">
            <div class="col-12 col-lg-5 col-xl-4 order-1 order-lg-1">
                {include './partials/editor/sidebar.latte'}
            </div>

            <div class="col-12 col-lg-7 col-xl-8 order-2 order-lg-2">
                {include './partials/editor/shell.latte'}
            </div>
        </div>
    </div>

    {include './partials/editor/modals.latte'}

    <script type="module" src="/ext/emoji-picker-element/index.js"></script>

    <script n:syntax="double">
        (() => {
            'use strict';

            const editorRoot = document.getElementById('tm-editor-root');
            const markdownField = document.getElementById('tm-editor-markdown');
            const titleField = document.getElementById('tm-editor-title');
            const loadFilterField = document.getElementById('tm-editor-load-filter');
            const loadEntryField = document.getElementById('tm-editor-load-entry');
            const entryTypeField = document.getElementById('tm-editor-entry-type');
            const scopeField = document.getElementById('tm-editor-scope');
            const slugField = document.getElementById('tm-editor-slug');
            const authorSlugField = document.getElementById('tm-editor-author-slug');
            const parentSlugField = document.getElementById('tm-editor-parent-slug');
            const parentSlugFieldContainer = parentSlugField ? parentSlugField.closest('.col-12') : null;
            const summaryField = document.getElementById('tm-editor-summary');
            const tagsField = document.getElementById('tm-editor-tags');
            const seoTitleField = document.getElementById('tm-editor-seo-title');
            const seoDescriptionField = document.getElementById('tm-editor-seo-description');
            const seoSocialTitleField = document.getElementById('tm-editor-seo-social-title');
            const seoSocialDescriptionField = document.getElementById('tm-editor-seo-social-description');
            const seoCanonicalUrlField = document.getElementById('tm-editor-seo-canonical-url');
            const seoRobotsField = document.getElementById('tm-editor-seo-robots');
            const seoExcludeFromSitemapField = document.getElementById('tm-editor-seo-exclude-from-sitemap');
            const sortOrderField = document.getElementById('tm-editor-sort-order');
            const sortOrderFieldContainer = sortOrderField ? sortOrderField.closest('.col-12') : null;
            const sortOrderHint = document.getElementById('tm-editor-sort-order-hint');
            const aggregateField = document.getElementById('tm-editor-aggregate');
            const aggregateFieldWrapper = aggregateField ? aggregateField.closest('.form-check') : null;
            const stickyField = document.getElementById('tm-editor-sticky');
            const featuredField = document.getElementById('tm-editor-featured');
            const featuredFieldWrapper = featuredField ? featuredField.closest('.form-check') : null;
            const fallbackCoverColorField = document.getElementById('tm-editor-fallback-cover-color');
            const fallbackCoverColorFieldContainer = fallbackCoverColorField ? fallbackCoverColorField.closest('.col-12') : null;
            const fallbackCoverColorCustomWrap = document.getElementById('tm-editor-fallback-cover-color-custom-wrap');
            const fallbackCoverColorCustomField = document.getElementById('tm-editor-fallback-cover-color-custom');
            const fallbackCoverColorRecentContainer = document.getElementById('tm-editor-fallback-cover-color-recent');
            const navigationField = document.getElementById('tm-editor-nav');
            const navigationFieldWrapper = navigationField ? navigationField.closest('.form-check') : null;
            const saveButton = document.getElementById('tm-editor-save');
            const saveEntryButton = document.getElementById('tm-editor-save-entry');
            const saveReturnButton = document.getElementById('tm-editor-save-return');
            const saveNewButton = document.getElementById('tm-editor-save-new');
            const saveActionButtons = Array.from(document.querySelectorAll('[data-tm-editor-save-action]'));
            const duplicateButton = document.getElementById('tm-editor-duplicate');
            const cancelButton = document.getElementById('tm-editor-cancel');
            const statusField = document.getElementById('tm-editor-status-field');
            const publishedAtLocalField = document.getElementById('tm-editor-published-at-local');
            const saveStatus = document.getElementById('tm-editor-save-status');
            const publishedLink = document.getElementById('tm-editor-published-link');
            const previewPane = document.getElementById('tm-editor-preview-pane');
            const metadataPane = document.getElementById('tm-editor-metadata-pane');
            const seoPane = document.getElementById('tm-editor-seo-pane');
            const pluginPanes = Array.from(document.querySelectorAll('[data-editor-plugin-pane]'));
            const writePane = document.getElementById('tm-editor-write-pane');
            const previewTarget = document.getElementById('tm-editor-preview');
            const previewStatus = document.getElementById('tm-editor-status');
            const tabButtons = document.querySelectorAll('#tinymash-editor-tabs [data-mode]');

            const previewUrl = editorRoot ? (editorRoot.dataset.previewUrl || '') : '';
            const editorUrl = editorRoot ? (editorRoot.dataset.editorUrl || '') : '';
            const draftUrl = editorRoot ? (editorRoot.dataset.draftUrl || '') : '';
            const draftDeleteUrl = editorRoot ? (editorRoot.dataset.draftDeleteUrl || '') : '';
            const saveEntryUrl = editorRoot ? (editorRoot.dataset.saveEntryUrl || '') : '';
            const cancelUrl = editorRoot ? (editorRoot.dataset.cancelUrl || '') : '';
            const slugCheckUrl = editorRoot ? (editorRoot.dataset.slugCheckUrl || '') : '';
            const contentSearchUrl = editorRoot ? (editorRoot.dataset.contentSearchUrl || '') : '';
            const mediaPickerUrl = editorRoot ? (editorRoot.dataset.mediaPickerUrl || '') : '';
            const imageUploadUrl = editorRoot ? (editorRoot.dataset.imageUploadUrl || '') : '';
            const imagesEnabled = editorRoot ? (editorRoot.dataset.imagesEnabled === '1') : false;
            const csrfToken = editorRoot ? (editorRoot.dataset.csrfToken || '') : '';
            const initialDraftId = editorRoot ? (editorRoot.dataset.loadedDraftId || '') : '';
            const initialRevisionId = editorRoot ? (editorRoot.dataset.loadedRevisionId || '') : '';
            const loadedEntryType = editorRoot ? (editorRoot.dataset.loadedEntryType || '') : '';
            const loadedEntryScope = editorRoot ? (editorRoot.dataset.loadedEntryScope || '') : '';
            const loadedEntryAuthorSlug = editorRoot ? (editorRoot.dataset.loadedEntryAuthorSlug || '') : '';
            const currentAuthorSlug = editorRoot ? (editorRoot.dataset.currentAuthorSlug || '') : '';
            const attachmentSessionId = editorRoot
                ? (editorRoot.dataset.attachmentSessionId || ('session_' + Math.random().toString(36).slice(2, 12)))
                : ('session_' + Math.random().toString(36).slice(2, 12));
            const autosaveEnabled = editorRoot ? (editorRoot.dataset.autosaveEnabled === '1') : false;
            const autosaveIntervalSeconds = editorRoot ? Math.min(180, Math.max(30, Number.parseInt(editorRoot.dataset.autosaveIntervalSeconds || '120', 10) || 120)) : 120;
            const emojiDataUrl = editorRoot ? (editorRoot.dataset.emojiDataUrl || '/ext/emoji-picker-data/en/github/data') : '/ext/emoji-picker-data/en/github/data';
            function parseEditorDatasetJson(key, fallback = []) {
                if (!editorRoot || !editorRoot.dataset || !Object.prototype.hasOwnProperty.call(editorRoot.dataset, key)) {
                    return fallback;
                }

                const rawValue = editorRoot.dataset[key] || '';
                if (rawValue === '') {
                    return fallback;
                }

                try {
                    return JSON.parse(rawValue);
                } catch (error) {
                    console.error('[tinymash] editor data JSON parse failed for ' + key, error);
                    return fallback;
                }
            }

            function parseEditorDatasetJsonArray(key) {
                const parsedValue = parseEditorDatasetJson(key, []);
                return Array.isArray(parsedValue) ? parsedValue : [];
            }

            const editorRevisions = parseEditorDatasetJsonArray('revisionsJson');
            const editorLinkableEntries = parseEditorDatasetJsonArray('linkableEntriesJson');
            const editorTagSuggestions = parseEditorDatasetJsonArray('tagSuggestionsJson');
            const editorCurrentFeaturedImage = parseEditorDatasetJson('currentFeaturedImageJson', []);
            const editorCurrentSocialImage = parseEditorDatasetJson('currentSocialImageJson', []);
            const slugStatus = document.getElementById('tm-editor-slug-status');
            const stateSummary = document.getElementById('tm-editor-state-summary');
            const currentDraftDeleteButton = document.getElementById('tm-editor-delete-current-draft');
            const draftsList = document.getElementById('tm-editor-drafts-list');
            const recentEntriesList = document.getElementById('tm-editor-recent-entries-list');
            const revisionsList = document.getElementById('tm-editor-revisions-list');
            const contentSearchStatus = document.getElementById('tm-editor-content-search-status');
            const contentSearchResults = document.getElementById('tm-editor-content-search-results');
            const loadSelectFallback = document.getElementById('tm-editor-load-select-fallback');
            const loadSelectActions = document.getElementById('tm-editor-load-select-actions');
            const deleteDraftModalElement = document.getElementById('tm-editor-delete-draft-modal');
            const deleteDraftName = document.getElementById('tm-editor-delete-draft-name');
            const confirmDeleteDraftButton = document.getElementById('tm-editor-confirm-delete-draft');
            const cancelModalElement = document.getElementById('tm-editor-cancel-modal');
            const cancelModalSummary = document.getElementById('tm-editor-cancel-modal-summary');
            const cancelModalDetail = document.getElementById('tm-editor-cancel-modal-detail');
            const cancelKeepButton = document.getElementById('tm-editor-cancel-keep');
            const cancelDiscardButton = document.getElementById('tm-editor-cancel-discard');
            const emojiPickerButton = document.getElementById('tm-editor-open-emoji-picker');
            const imageUploadButton = document.getElementById('tm-editor-open-image-upload');
            const imageInput = document.getElementById('tm-editor-image-input');
            const externalLinkButton = document.getElementById('tm-editor-open-external-link');
            const externalLinkModalElement = document.getElementById('tm-editor-external-link-modal');
            const externalLinkUrlField = document.getElementById('tm-editor-external-link-url');
            const externalLinkTextField = document.getElementById('tm-editor-external-link-text');
            const externalLinkNewTabField = document.getElementById('tm-editor-external-link-new-tab');
            const externalLinkInsertButton = document.getElementById('tm-editor-external-link-insert');
            const internalLinkButton = document.getElementById('tm-editor-open-internal-link');
            const internalLinkModalElement = document.getElementById('tm-editor-internal-link-modal');
            const internalLinkFilterField = document.getElementById('tm-editor-internal-link-filter');
            const internalLinkTargetField = document.getElementById('tm-editor-internal-link-target');
            const internalLinkTextField = document.getElementById('tm-editor-internal-link-text');
            const internalLinkNewTabField = document.getElementById('tm-editor-internal-link-new-tab');
            const internalLinkInsertButton = document.getElementById('tm-editor-internal-link-insert');
            const featuredImageField = document.getElementById('tm-editor-featured-image');
            const featuredImageOpenButton = document.getElementById('tm-editor-open-featured-image-picker');
            const featuredImageClearButton = document.getElementById('tm-editor-clear-featured-image');
            const featuredImageSummary = document.getElementById('tm-editor-featured-image-summary');
            const featuredImageDisabledValueField = document.getElementById('tm-editor-featured-image-disabled-value');
            const featuredImagePreview = document.getElementById('tm-editor-featured-image-preview');
            const seoSocialImageField = document.getElementById('tm-editor-seo-social-image');
            const seoSocialImageOpenButton = document.getElementById('tm-editor-open-seo-social-image-picker');
            const seoSocialImageClearButton = document.getElementById('tm-editor-clear-seo-social-image');
            const seoSocialImageSummary = document.getElementById('tm-editor-seo-social-image-summary');
            const seoSocialImageDisabledValueField = document.getElementById('tm-editor-seo-social-image-disabled-value');
            const seoSocialImagePreview = document.getElementById('tm-editor-seo-social-image-preview');
            const attachedImagesContainer = document.getElementById('tm-editor-attached-images');
            const featuredImageModalElement = document.getElementById('tm-editor-featured-image-modal');
            const featuredImageModalLabel = document.getElementById('tm-editor-featured-image-modal-label');
            const featuredImageFilterField = document.getElementById('tm-editor-featured-image-filter');
            const featuredImagePickerGrid = document.getElementById('tm-editor-featured-image-picker-grid');
            const featuredImageRemoveButton = document.getElementById('tm-editor-featured-image-remove');
            const imagePickerUploadButton = document.getElementById('tm-editor-image-picker-upload');
            const imagePickerInsertSelectedButton = document.getElementById('tm-editor-image-picker-insert-selected');
            const featuredImageSourceButtons = document.querySelectorAll('#tm-editor-featured-image-modal [data-source]');
            const emojiAutocomplete = document.getElementById('tm-editor-emoji-autocomplete');
            const tagsAutocomplete = document.getElementById('tm-editor-tags-autocomplete');
            const emojiPickerModalElement = document.getElementById('tm-editor-emoji-modal');
            const emojiPickerElement = document.getElementById('tm-editor-emoji-picker');
            const externalLinkNewTabStorageKey = 'tinymash.editor.externalLinkNewTab';
            const internalLinkNewTabStorageKey = 'tinymash.editor.internalLinkNewTab';
            const fallbackCoverColorStorageKey = 'tinymash.editor.blocksRecentCoverColors';

            let lastPreviewSource = null;
            let loadedEntryId = editorRoot ? (editorRoot.dataset.loadedEntryId || '') : '';
            let loadedDraftId = initialDraftId;
            let loadedRevisionId = initialRevisionId;
            let slugTouched = loadedEntryId !== '';
            let lastAutoSlug = slugField ? slugField.value.trim() : '';
            let slugCheckTimer = null;
            let slugCheckSequence = 0;
            let autosaveTimer = null;
            let hasUnsavedChanges = false;
            let draftSaveInFlight = false;
            let saveEntryInFlight = false;
            let draftSavePromise = null;
            let draftSaveController = null;
            let draftSaveReason = '';
            let pendingDeleteDraftId = '';
            let pendingDeleteDraftTitle = '';
            let pendingDeleteIsCurrent = false;
            let emojiAutocompleteEntries = [];
            let emojiAutocompletePromise = null;
            let emojiAutocompleteMatches = [];
            let emojiAutocompleteIndex = -1;
            let emojiAutocompleteTokenStart = -1;
            let emojiAutocompleteTokenEnd = -1;
            let emojiAutocompleteRequestId = 0;
            let tagAutocompleteMatches = [];
            let tagAutocompleteIndex = -1;
            let internalLinkFilterTouched = false;
            let loadEntryOptionRecords = [];
            let contentSearchTimer = null;
            let contentSearchController = null;
            let featuredImageSource = 'attached';
            let imagePickerTarget = 'featured';
            let lastSuggestedSortOrder = null;
            let sortOrderTouched = Boolean(initialDraftId || initialRevisionId || loadedEntryId);
            let attachedImageRecords = [];
            let featuredImageRecords = [];
            let libraryImageRecords = [];
            const mediaPickerSourceLoaded = {
                attached: false,
                recent: false,
                library: false
            };
            const mediaPickerSourceLoading = {
                attached: false,
                recent: false,
                library: false
            };
            const initialSelectedImageRecords = [editorCurrentFeaturedImage, editorCurrentSocialImage]
                .map((record) => normalizeFeaturedImageRecord(record))
                .filter((record) => record);

            function isCustomFallbackCoverColor(value) {
                return /^#[0-9a-f]{6}$/i.test(String(value || '').trim());
            }

            function normalizeFallbackCoverColor(value) {
                const normalized = String(value || '').trim().toLowerCase();
                if (['', 'slate', 'blue', 'green', 'amber', 'berry'].includes(normalized)) {
                    return normalized;
                }

                return isCustomFallbackCoverColor(normalized) ? normalized : '';
            }

            function loadRecentFallbackCoverColors() {
                if (!window.localStorage) {
                    return [];
                }

                try {
                    const stored = JSON.parse(window.localStorage.getItem(fallbackCoverColorStorageKey) || '[]');
                    if (!Array.isArray(stored)) {
                        return [];
                    }

                    return stored.map((value) => normalizeFallbackCoverColor(value)).filter((value) => isCustomFallbackCoverColor(value));
                } catch (error) {
                    return [];
                }
            }

            function saveRecentFallbackCoverColors(colors) {
                if (!window.localStorage) {
                    return;
                }

                try {
                    window.localStorage.setItem(fallbackCoverColorStorageKey, JSON.stringify(colors));
                } catch (error) {
                    // Ignore storage failures.
                }
            }

            function rememberFallbackCoverColor(value) {
                const normalized = normalizeFallbackCoverColor(value);
                if (!isCustomFallbackCoverColor(normalized)) {
                    return;
                }

                const recentColors = loadRecentFallbackCoverColors().filter((color) => color !== normalized);
                recentColors.unshift(normalized);
                saveRecentFallbackCoverColors(recentColors.slice(0, 8));
            }

            function renderRecentFallbackCoverColors() {
                if (!fallbackCoverColorRecentContainer) {
                    return;
                }

                const recentColors = loadRecentFallbackCoverColors();
                fallbackCoverColorRecentContainer.innerHTML = '';
                fallbackCoverColorRecentContainer.classList.toggle('d-none', recentColors.length === 0);
                recentColors.forEach((color) => {
                    const button = document.createElement('button');
                    button.type = 'button';
                    button.className = 'btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-2';
                    button.dataset.color = color;
                    button.title = color;
                    button.innerHTML = '<span class="border rounded-1 d-inline-block" style="width: 1rem; height: 1rem; background-color: ' + escapeHtml(color) + ';"></span><span class="font-monospace small">' + escapeHtml(color) + '</span>';
                    fallbackCoverColorRecentContainer.appendChild(button);
                });
            }

            function getFallbackCoverColorValue() {
                if (!fallbackCoverColorField) {
                    return '';
                }

                if (fallbackCoverColorField.value === 'custom') {
                    return normalizeFallbackCoverColor(fallbackCoverColorCustomField ? fallbackCoverColorCustomField.value : '');
                }

                return normalizeFallbackCoverColor(fallbackCoverColorField.value);
            }

            function updateFallbackCoverColorUi() {
                const showCustom = fallbackCoverColorField && fallbackCoverColorField.value === 'custom';
                if (fallbackCoverColorCustomWrap) {
                    fallbackCoverColorCustomWrap.classList.toggle('d-none', !showCustom);
                }
                if (fallbackCoverColorCustomField) {
                    fallbackCoverColorCustomField.disabled = !showCustom;
                }
                renderRecentFallbackCoverColors();
            }

            function applyFallbackCoverColorValue(value) {
                const normalized = normalizeFallbackCoverColor(value);
                if (!fallbackCoverColorField) {
                    return;
                }

                if (isCustomFallbackCoverColor(normalized)) {
                    fallbackCoverColorField.value = 'custom';
                    if (fallbackCoverColorCustomField) {
                        fallbackCoverColorCustomField.value = normalized;
                    }
                    rememberFallbackCoverColor(normalized);
                } else {
                    fallbackCoverColorField.value = normalized;
                }

                updateFallbackCoverColorUi();
            }

            function getBootstrapModal(modalElement) {
                if (!modalElement || !window.bootstrap || !window.bootstrap.Modal) {
                    return null;
                }

                return window.bootstrap.Modal.getOrCreateInstance(modalElement);
            }

            function getLoadEntryOptionRecordsFromDom() {
                if (!loadEntryField) {
                    return [];
                }

                return Array.from(loadEntryField.options).slice(1).map((option) => ({
                    id: option.value || '',
                    label: option.textContent || 'Untitled content',
                    filterText: option.dataset.filterText || option.textContent || '',
                })).filter((option) => option.id !== '');
            }

            function renderLoadEntryOptions(entryOptions, selectedId = '') {
                if (!loadEntryField) {
                    return;
                }

                const normalizedSelectedId = String(selectedId || '');
                const optionMarkup = ['<option value="">Keep current composer state</option>'];
                (entryOptions || []).forEach((entryOption) => {
                    const optionId = String(entryOption.id || '');
                    if (optionId === '') {
                        return;
                    }

                    const selected = normalizedSelectedId !== '' && normalizedSelectedId === optionId ? ' selected' : '';
                    const label = entryOption.label || 'Untitled content';
                    const filterText = entryOption.filterText || label;
                    optionMarkup.push(
                        '<option value="' + escapeHtml(optionId) + '" data-filter-text="' + escapeHtml(filterText) + '"' + selected + '>' + escapeHtml(label) + '</option>'
                    );
                });
                loadEntryField.innerHTML = optionMarkup.join('');
            }

            function setContentSearchStatus(message, className = 'form-text') {
                if (!contentSearchStatus) {
                    return;
                }

                contentSearchStatus.className = className;
                contentSearchStatus.textContent = message;
            }

            function clearContentSearchResults() {
                if (contentSearchResults) {
                    contentSearchResults.innerHTML = '';
                    contentSearchResults.classList.add('d-none');
                }
            }

            function renderContentSearchResults(results) {
                if (!contentSearchResults) {
                    return;
                }

                if (!Array.isArray(results) || results.length === 0) {
                    clearContentSearchResults();
                    return;
                }

                contentSearchResults.innerHTML = results.map((result) => {
                    const title = result.title || result.label || 'Untitled content';
                    const meta = [result.type || '', result.scope_label || result.scope || '', result.status || '']
                        .filter((value) => String(value || '').trim() !== '')
                        .join(' · ');
                    const path = result.path || '';
                    return '<a class="btn btn-outline-secondary btn-sm text-start" href="' + escapeHtml(result.url || (editorUrl + '?entry=' + encodeURIComponent(result.id || ''))) + '">'
                        + '<span class="d-block fw-semibold">' + escapeHtml(title) + '</span>'
                        + '<span class="d-block small text-body-secondary">' + escapeHtml(meta) + (path !== '' ? ' · ' + escapeHtml(path) : '') + '</span>'
                        + '</a>';
                }).join('');
                contentSearchResults.classList.remove('d-none');
            }

            function searchEditorContentNow() {
                if (!loadFilterField || !contentSearchUrl || !csrfToken) {
                    return;
                }

                const query = loadFilterField.value.trim();
                if (query.length < 2) {
                    if (contentSearchController) {
                        contentSearchController.abort();
                        contentSearchController = null;
                    }
                    clearContentSearchResults();
                    setContentSearchStatus(query === '' ? '' : 'Type one more character.');
                    return;
                }

                if (contentSearchController) {
                    contentSearchController.abort();
                }
                contentSearchController = new AbortController();
                setContentSearchStatus('Searching...');

                const body = new URLSearchParams();
                body.set('tinymash_csrf', csrfToken);
                body.set('q', query);
                body.set('limit', '12');

                fetch(contentSearchUrl, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: body.toString(),
                    signal: contentSearchController.signal
                })
                    .then((response) => response.json().then((payload) => ({ response, payload })))
                    .then(({ response, payload }) => {
                        if (!response.ok) {
                            throw new Error(payload && payload.error ? payload.error : 'Content search failed.');
                        }
                        const results = Array.isArray(payload.results) ? payload.results : [];
                        renderContentSearchResults(results);
                        if (results.length === 0) {
                            setContentSearchStatus(payload.message || 'No matching content found.', 'form-text text-body-secondary');
                            return;
                        }
                        setContentSearchStatus(results.length + ' matching item' + (results.length === 1 ? '' : 's') + '.', 'form-text text-body-secondary');
                    })
                    .catch((error) => {
                        if (error && error.name === 'AbortError') {
                            return;
                        }
                        clearContentSearchResults();
                        setContentSearchStatus(error && error.message ? error.message : 'Content search failed.', 'form-text text-danger');
                    });
            }

            function queueContentSearch() {
                if (contentSearchTimer) {
                    window.clearTimeout(contentSearchTimer);
                }
                contentSearchTimer = window.setTimeout(searchEditorContentNow, 250);
            }

            function initializeContentSearch() {
                if (!loadFilterField || !contentSearchUrl || !contentSearchResults) {
                    return;
                }

                if (loadSelectFallback) {
                    loadSelectFallback.classList.add('d-none');
                }
                if (loadSelectActions) {
                    loadSelectActions.classList.add('d-none');
                }
                loadFilterField.addEventListener('input', queueContentSearch);
                loadFilterField.addEventListener('keydown', (event) => {
                    if (event.key === 'Enter') {
                        event.preventDefault();
                    }
                });
                setContentSearchStatus('');
            }

            function filterLoadOptions() {
                if (!loadFilterField || !loadEntryField) {
                    return;
                }

                if (loadEntryOptionRecords.length === 0) {
                    loadEntryOptionRecords = getLoadEntryOptionRecordsFromDom();
                }

                const needle = loadFilterField.value.trim().toLowerCase();
                const selectedId = loadEntryField.value || '';
                const matchingOptions = needle === ''
                    ? loadEntryOptionRecords
                    : loadEntryOptionRecords.filter((option) => String(option.filterText || option.label || '').toLowerCase().includes(needle));
                const selectedStillVisible = selectedId !== '' && matchingOptions.some((option) => String(option.id || '') === selectedId);
                renderLoadEntryOptions(matchingOptions, selectedStillVisible ? selectedId : '');
            }

            function getTagAutocompleteContext() {
                if (!tagsField) {
                    return null;
                }

                const value = tagsField.value || '';
                const selectionStart = Number.isInteger(tagsField.selectionStart) ? tagsField.selectionStart : value.length;
                const prefix = value.slice(0, selectionStart);
                const tokenStart = Math.max(prefix.lastIndexOf(','), prefix.lastIndexOf(' ')) + 1;
                const token = prefix.slice(tokenStart).trim().replace(/^#/, '').toLowerCase();
                return {
                    value,
                    selectionStart,
                    tokenStart,
                    token,
                };
            }

            function hideTagAutocomplete() {
                if (!tagsAutocomplete) {
                    return;
                }
                tagsAutocomplete.classList.add('d-none');
                tagsAutocomplete.innerHTML = '';
                tagAutocompleteMatches = [];
                tagAutocompleteIndex = -1;
            }

            function renderTagAutocomplete() {
                if (!tagsAutocomplete) {
                    return;
                }

                if (!Array.isArray(tagAutocompleteMatches) || tagAutocompleteMatches.length === 0) {
                    hideTagAutocomplete();
                    return;
                }

                tagsAutocomplete.innerHTML = tagAutocompleteMatches.map((tag, index) => {
                    const activeClass = index === tagAutocompleteIndex ? ' active' : '';
                    return '<button class="list-group-item list-group-item-action' + activeClass + '" type="button" data-tag-index="' + index + '">#' + escapeHtml(tag) + '</button>';
                }).join('');
                tagsAutocomplete.classList.remove('d-none');
            }

            function applyTagSuggestion(tag) {
                if (!tagsField || !tag) {
                    return;
                }

                const context = getTagAutocompleteContext();
                if (!context) {
                    return;
                }

                const before = context.value.slice(0, context.tokenStart).replace(/\s+$/, '');
                const after = context.value.slice(context.selectionStart).replace(/^\s+/, '');
                const replacement = (before !== '' ? before + ' ' : '') + '#' + tag + ', ' + after;
                tagsField.value = replacement.replace(/\s+,/g, ',').trimStart();
                const caretPosition = ((before !== '' ? before + ' ' : '') + '#' + tag + ', ').length;
                tagsField.focus();
                tagsField.setSelectionRange(caretPosition, caretPosition);
                hideTagAutocomplete();
            }

            function updateTagAutocomplete() {
                if (!tagsField || !tagsAutocomplete) {
                    return;
                }

                const context = getTagAutocompleteContext();
                if (!context || context.token.length < 1) {
                    hideTagAutocomplete();
                    return;
                }

                const existingTokens = String(tagsField.value || '')
                    .split(/[\s,]+/u)
                    .map((token) => token.trim().replace(/^#/, '').toLowerCase())
                    .filter((token) => token !== '');

                tagAutocompleteMatches = editorTagSuggestions
                    .filter((tag) => typeof tag === 'string' && tag.toLowerCase().includes(context.token))
                    .filter((tag) => tag.toLowerCase() === context.token || !existingTokens.includes(tag.toLowerCase()))
                    .slice(0, 8);
                tagAutocompleteIndex = tagAutocompleteMatches.length > 0 ? 0 : -1;
                renderTagAutocomplete();
            }

            function escapeHtml(value) {
                return String(value || '')
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function getDraftUrl(draftId) {
                return editorUrl + '?draft=' + encodeURIComponent(draftId);
            }

            function getEntryUrl(entryId) {
                return editorUrl + '?entry=' + encodeURIComponent(entryId);
            }
